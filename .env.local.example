# ─────────────────────────────────────────────────────────────────────
 # StudioBlack — local environment variables                                                                                                                                     
 #                                                     
 # Copy this file to `.env.local` and fill in real values. `.env.local`                                                                                                          
 # is git-ignored. On Vercel, set the same vars under                                                                                                                            
 # Project Settings → Environment Variables.      
 # ─────────────────────────────────────────────────────────────────────                                                                                                         
                                                               
                                                   
 # ── Database & Storage (Supabase) ───────────────────────────────────                                                                                                          
 # Postgres connection string — pooled connection for serverless.                                                                                                                
 DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true                                                                                                           

 # Supabase project URL — exposed to the browser for storage uploads.
 NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co

 # Service-role key for server-side storage operations. SECRET.
 SUPABASE_SERVICE_ROLE_KEY=


 # ── Auth (better-auth) ──────────────────────────────────────────────
 # 32+ char random string. Generate with: openssl rand -base64 32
 BETTER_AUTH_SECRET=

 # Public URL the app is reachable at — auth callbacks read this.
 # Local dev: http://localhost:3000. Production: your prod URL.
 BETTER_AUTH_URL=http://localhost:3000


 # ── App ─────────────────────────────────────────────────────────────
 # Same as BETTER_AUTH_URL most of the time. Used by client-side code
 # that needs to know its own origin (download links, share buttons).
 # NEXT_PUBLIC_APP_URL=http://localhost:3000


 # ── Email (Brevo SMTP) ──────────────────────────────────────────────
 # All SMTP_* are optional — email features (magic links, invites,
 # review notifications) degrade gracefully if missing.
 SMTP_HOST=smtp-relay.brevo.com
 SMTP_PORT=587
 SMTP_USER=
 SMTP_PASS=

 # Display name + address shown as the From of every transactional email.
 EMAIL_FROM=StudioBlack <noreply@yourdomain.com>


 # ── Google OAuth (optional, for "Sign in with Google") ──────────────
 # Reserved for the landing-page + Google sign-in feature (#11). Safe
 # to leave blank until that lands.
 GOOGLE_CLIENT_ID=
 GOOGLE_CLIENT_SECRET=


 # ── PostHog — error tracking + product analytics ────────────────────
 # Project API key (phc_…). Public; safe to expose in the browser bundle.
 NEXT_PUBLIC_POSTHOG_KEY=

 # PostHog Cloud host. EU: https://eu.i.posthog.com — US: https://us.i.posthog.com
 NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

 # Optional. Override the assets host (recording, autocapture bundles).
 # Only set when using a custom PostHog domain — Cloud users can leave
 # this blank; the default eu-assets / us-assets subdomain is derived.
 # NEXT_PUBLIC_POSTHOG_ASSETS_HOST=

 # Source map upload (production builds only). When both are set, the
 # build uploads minified bundle source maps so PostHog can symbolicate
 # production stack traces. Local dev and CI without these env vars
 # build normally and skip the upload step.
 #
 # POSTHOG_API_KEY — Personal API key with `error_tracking:write` scope.
 # SECRET. Create at PostHog → Settings → Personal API keys.
 # POSTHOG_API_KEY=
 #
 # POSTHOG_PROJECT_ID — Numeric project ID (visible in Project settings
 # or in the project URL: /project/<id>/...). Not secret.
 # POSTHOG_PROJECT_ID=


 # ── Vendor Management (F7) ──────────────────────────────────────────
 # AES-256-GCM key for encrypting vendor `bank_details` at rest.
 # 32 bytes, hex-encoded (64 chars). SECRET.
 #
 # Generate one fresh per environment, then save it somewhere safe —
 # losing this key makes every previously-stored bank detail unreadable
 # (the data is not recoverable; the only fix is manual re-entry).
 #
 # Generate with:
 #   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
 #
 # Optional: only required when bank-details endpoints are exercised.
 # The vendorManagement feature flag is off by default in features.ts.
  VENDOR_ENCRYPTION_KEY=


 # ── Dev-only debugging flags (safe to omit) ─────────────────────────
 # Logger threshold. debug | info | warn | error. Defaults to debug
 # in dev, info in prod.
 # LOG_LEVEL=debug

 # When "1" AND NODE_ENV !== production, the bulk-import row-failure
 # message includes the raw pg error text for triage. Off by default.
 # IMPORT_PG_DEBUG=0